generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  LANDLORD
  MANAGER
  TENANT
}

enum PropertyStatus {
  VACANT
  OCCUPIED
  MAINTENANCE
  INACTIVE
}

enum LeaseStatus {
  DRAFT
  ACTIVE
  SIGNED
  EXPIRED
  TERMINATED
}

enum ChargeStatus {
  OPEN
  PARTIAL
  PAID
  LATE
  VOID
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  WAITING_TENANT
  COMPLETED
  CLOSED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String?
  role         UserRole @default(TENANT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant?
}

model Property {
  id          String         @id @default(cuid())
  nickname    String?
  address1    String
  address2    String?
  city        String
  state       String         @default("FL")
  zip         String
  bedrooms    Int?
  bathrooms   Float?
  status      PropertyStatus @default(VACANT)
  monthlyRent Decimal?       @db.Decimal(10, 2)
  deposit     Decimal?       @db.Decimal(10, 2)
  hoaName     String?
  latitude    Decimal?       @db.Decimal(9, 6)
  longitude   Decimal?       @db.Decimal(9, 6)
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  leases      Lease[]
  documents   Document[]
  maintenance MaintenanceRequest[]
}

model Tenant {
  id             String   @id @default(cuid())
  userId         String?  @unique
  firstName      String
  lastName       String
  email          String?
  phone          String?
  emergencyName  String?
  emergencyPhone String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User?    @relation(fields: [userId], references: [id])
  leases         LeaseTenant[]
  documents      Document[]
  maintenance    MaintenanceRequest[]
}

model LeaseTemplate {
  id          String   @id @default(cuid())
  name        String
  version     String
  jurisdiction String  @default("Florida")
  bodyMarkdown String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  leases      Lease[]
}

model Lease {
  id             String      @id @default(cuid())
  propertyId     String
  templateId     String?
  status         LeaseStatus @default(DRAFT)
  startDate      DateTime
  endDate        DateTime
  monthlyRent    Decimal     @db.Decimal(10, 2)
  securityDeposit Decimal?   @db.Decimal(10, 2)
  petFeeMonthly  Decimal?    @db.Decimal(10, 2)
  repairThreshold Decimal?   @db.Decimal(10, 2)
  pdfPath        String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  property       Property    @relation(fields: [propertyId], references: [id])
  template       LeaseTemplate? @relation(fields: [templateId], references: [id])
  tenants        LeaseTenant[]
  charges        RentCharge[]
  documents      Document[]
}

model LeaseTenant {
  leaseId  String
  tenantId String
  primary  Boolean @default(false)
  lease    Lease   @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([leaseId, tenantId])
}

model RentCharge {
  id          String       @id @default(cuid())
  leaseId     String
  dueDate     DateTime
  description String
  amount      Decimal      @db.Decimal(10, 2)
  lateFee     Decimal      @default(0) @db.Decimal(10, 2)
  status      ChargeStatus @default(OPEN)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  lease       Lease        @relation(fields: [leaseId], references: [id])
  payments    RentPayment[]
}

model RentPayment {
  id        String   @id @default(cuid())
  chargeId  String
  paidAt    DateTime
  amount    Decimal  @db.Decimal(10, 2)
  method    String
  reference String?
  notes     String?
  createdAt DateTime @default(now())
  charge    RentCharge @relation(fields: [chargeId], references: [id])
}

model MaintenanceRequest {
  id          String            @id @default(cuid())
  propertyId  String
  tenantId    String?
  title       String
  description String
  status      MaintenanceStatus @default(OPEN)
  priority    String            @default("normal")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  property    Property          @relation(fields: [propertyId], references: [id])
  tenant      Tenant?           @relation(fields: [tenantId], references: [id])
}

model Document {
  id         String   @id @default(cuid())
  propertyId String?
  tenantId   String?
  leaseId    String?
  title      String
  kind       String
  path       String
  createdAt  DateTime @default(now())
  property   Property? @relation(fields: [propertyId], references: [id])
  tenant     Tenant?   @relation(fields: [tenantId], references: [id])
  lease      Lease?    @relation(fields: [leaseId], references: [id])
}
